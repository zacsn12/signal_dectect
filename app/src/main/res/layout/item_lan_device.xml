<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="8dp"
    android:background="@drawable/bg_main_background"
    android:elevation="6dp"
    android:stateListAnimator="@animator/card_press_anim">

    <!-- Card Background shape (Rounded rectangle) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_card_rounded" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_ip_address"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="192.168.1.100"
                android:textSize="20sp"
                android:fontFamily="sans-serif-black"
                android:textColor="#0F172A" />

            <TextView
                android:id="@+id/tv_device_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📷 摄像头设备"
                android:textSize="12sp"
                android:fontFamily="sans-serif-bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_gradient_lan"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_hostname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Unknown"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#475569"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tv_mac_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MAC: Unknown"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:textColor="#94A3B8"
            android:layout_marginTop="4dp" />
    </LinearLayout>
</FrameLayout>
