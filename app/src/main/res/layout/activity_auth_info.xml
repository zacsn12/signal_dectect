<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F5F7">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#0A1E36"
        android:paddingTop="24dp">
        
        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_back"
            android:layout_gravity="start|center_vertical"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="授权信息"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:fontFamily="sans-serif-black" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_rounded"
        android:backgroundTint="#FFFFFF"
        android:elevation="4dp"
        android:layout_margin="16dp"
        android:padding="16dp">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="12dp">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="授权状态"
                android:textColor="#666666"
                android:textSize="16sp" />
            <TextView
                android:id="@+id/tv_auth_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="已授权"
                android:textColor="#4CAF50"
                android:textStyle="bold"
                android:textSize="16sp" />
        </LinearLayout>
        
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="12dp">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="授权序列号"
                android:textColor="#666666"
                android:textSize="16sp" />
            <TextView
                android:id="@+id/tv_serial_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SN-XXXXXXXX"
                android:textColor="#333333"
                android:textSize="16sp" />
        </LinearLayout>
        
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="12dp">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="有效期至"
                android:textColor="#666666"
                android:textSize="16sp" />
            <TextView
                android:id="@+id/tv_valid_until"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2099-12-31"
                android:textColor="#333333"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
