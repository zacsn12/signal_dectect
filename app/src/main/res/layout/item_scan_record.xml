<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="8dp"
    android:background="@drawable/bg_main_background"
    android:elevation="4dp"
    android:stateListAnimator="@animator/card_press_anim">

    <!-- Card Background shape (Rounded rectangle) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_card_rounded" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp">

        <CheckBox
            android:id="@+id/checkbox_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginEnd="16dp"
            android:buttonTint="@color/primary" />

        <!-- Icon container -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_icon_circle_blue"
            android:layout_marginEnd="16dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_bluetooth"
                app:tint="@color/primary" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_scan_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="蓝牙巡检"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black"
                android:textColor="#0F172A" />

            <TextView
                android:id="@+id/tv_scan_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="2024-01-01 12:00"
                android:textColor="#64748B"
                android:fontFamily="sans-serif-medium"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_record_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="记录名称"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tv_device_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="设备数: 10"
                    android:background="@drawable/bg_pill_gray"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textColor="#475569"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tv_apple_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Apple 设: 2"
                    android:background="@drawable/bg_pill_rose"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textColor="#EF4444"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
