<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8FAFC"
    android:scrollbars="none">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false">

        <!-- Top Police Blue Background Header Block -->
        <View
            android:id="@+id/header_background"
            android:layout_width="0dp"
            android:layout_height="240dp"
            android:background="#0A1E36"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Decorative Radar Watermark -->
        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:background="@drawable/bg_radar_ring"
            android:alpha="0.15"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- System Greeting/Title -->
        <TextView
            android:id="@+id/tv_greeting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="智能信号感知系统"
            android:textSize="26sp"
            android:fontFamily="sans-serif-black"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.05"
            android:layout_marginTop="40dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="公安无线安全与摄像头筛查终端"
            android:textSize="14sp"
            android:textColor="#94A3B8"
            android:layout_marginTop="6dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toBottomOf="@id/tv_greeting"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- System Status Tag -->
        <LinearLayout
            android:id="@+id/status_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_pill_blue"
            android:backgroundTint="#223B82F6"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:layout_marginTop="16dp"
            android:layout_marginStart="24dp"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
            app:layout_constraintStart_toStartOf="parent">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_icon_circle_green"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="系统就绪 · 实时保护中"
                android:textColor="#93C5FD"
                android:textSize="11sp"
                android:fontFamily="sans-serif-bold" />
        </LinearLayout>

        <!-- Bluetooth Inspect Card (Square) -->
        <FrameLayout
            android:id="@+id/card_bluetooth_inspect"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintDimensionRatio="1:1"
            android:layout_marginTop="28dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_card_rounded"
            android:stateListAnimator="@animator/card_press_anim"
            android:elevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/status_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/card_wifi_inspect">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="20dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_circle_blue"
                    android:backgroundTint="#EFF6FF">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_bluetooth"
                        app:tint="#2563EB"
                        android:layout_gravity="center" />
                </FrameLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="蓝牙无线巡检"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#0A1E36" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="BLE / Classic"
                    android:textSize="11sp"
                    android:textColor="#2563EB"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>
        </FrameLayout>

        <!-- WiFi Inspect Card (Square) -->
        <FrameLayout
            android:id="@+id/card_wifi_inspect"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintDimensionRatio="1:1"
            android:layout_marginTop="28dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="24dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_card_rounded"
            android:stateListAnimator="@animator/card_press_anim"
            android:elevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/status_container"
            app:layout_constraintStart_toEndOf="@id/card_bluetooth_inspect"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="20dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_circle_blue"
                    android:backgroundTint="#EFF6FF">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_wifi"
                        app:tint="#2563EB"
                        android:layout_gravity="center" />
                </FrameLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="WiFi无线巡检"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#0A1E36" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2.4G / 5G / 6G"
                    android:textSize="11sp"
                    android:textColor="#10B981"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>
        </FrameLayout>

        <!-- LAN Scan Card (Wide) -->
        <FrameLayout
            android:id="@+id/card_lan_scan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_card_rounded"
            android:stateListAnimator="@animator/card_press_anim"
            android:elevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/card_bluetooth_inspect"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_icon_circle_blue"
                    android:backgroundTint="#EFF6FF">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_lan"
                        app:tint="#2563EB"
                        android:layout_gravity="center" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="局域网设备扫描"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="#0A1E36" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="内网摄像头与未知连网终端排查"
                        android:textSize="12sp"
                        android:textColor="#64748B"
                        android:layout_marginTop="4dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="摄像头探测"
                            android:textColor="#F59E0B"
                            android:background="@drawable/bg_pill_orange"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-bold" />

                        <Space
                            android:layout_width="8dp"
                            android:layout_height="wrap_content" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="内网安全扫描"
                            android:textColor="#2563EB"
                            android:background="@drawable/bg_pill_blue"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-bold" />
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#64748B"
                    android:layout_marginStart="8dp" />

            </LinearLayout>
        </FrameLayout>

        <!-- Bottom Disclaimer/Police Brand Footer -->
        <LinearLayout
            android:id="@+id/police_footer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="120dp"
            app:layout_constraintTop_toBottomOf="@id/card_lan_scan"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="网络安全感知系统 · 移动终端版"
                android:textSize="11sp"
                android:textColor="#94A3B8"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="仅限公安业务与授权安全评估使用"
                android:textSize="10sp"
                android:textColor="#CBD5E1"
                android:layout_marginTop="4dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
