<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8FAFC"
    android:scrollbars="none">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false">

        <!-- Top Police Blue Background Header Block -->
        <View
            android:id="@+id/header_background"
            android:layout_width="0dp"
            android:layout_height="170dp"
            android:background="#0A1E36"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Decorative Radar Watermark -->
        <View
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:background="@drawable/bg_radar_ring"
            android:alpha="0.15"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- System Greeting/Title -->
        <TextView
            android:id="@+id/tv_greeting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="智能信号感知系统"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.05"
            android:layout_marginTop="20dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="公安无线安全与摄像头筛查终端"
            android:textSize="13sp"
            android:textColor="#94A3B8"
            android:layout_marginTop="4dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toBottomOf="@id/tv_greeting"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- System Status Tag -->
        <LinearLayout
            android:id="@+id/status_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_pill_blue"
            android:backgroundTint="#223B82F6"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:layout_marginTop="12dp"
            android:layout_marginStart="24dp"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
            app:layout_constraintStart_toStartOf="parent">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_icon_circle_green"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="系统就绪 · 实时保护中"
                android:textColor="#93C5FD"
                android:textSize="11sp"
                android:fontFamily="sans-serif-bold" />
        </LinearLayout>



        <!-- Bluetooth Inspect Card (Square) -->
        <FrameLayout
            android:id="@+id/card_bluetooth_inspect"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintDimensionRatio="1:1"
            android:layout_marginTop="16dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_card_rounded"
            android:stateListAnimator="@animator/card_press_anim"
            android:elevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/status_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/card_wifi_inspect">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_circle_blue"
                    android:backgroundTint="#EFF6FF">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_bluetooth"
                        app:tint="#2563EB"
                        android:layout_gravity="center" />
                </FrameLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="蓝牙巡检"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#0A1E36" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="BLE / Classic"
                    android:textSize="11sp"
                    android:textColor="#2563EB"
                    android:layout_marginTop="3dp"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>
        </FrameLayout>

        <!-- WiFi Inspect Card (Square) -->
        <FrameLayout
            android:id="@+id/card_wifi_inspect"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintDimensionRatio="1:1"
            android:layout_marginTop="16dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="24dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_card_rounded"
            android:stateListAnimator="@animator/card_press_anim"
            android:elevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/status_container"
            app:layout_constraintStart_toEndOf="@id/card_bluetooth_inspect"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_circle_blue"
                    android:backgroundTint="#EFF6FF">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_wifi"
                        app:tint="#2563EB"
                        android:layout_gravity="center" />
                </FrameLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="WiFi巡检"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#0A1E36" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2.4G / 5G"
                    android:textSize="11sp"
                    android:textColor="#10B981"
                    android:layout_marginTop="3dp"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>
        </FrameLayout>

        <!-- LAN Scan Card (Square) -->
        <FrameLayout
            android:id="@+id/card_lan_scan"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintDimensionRatio="1:1"
            android:layout_marginTop="12dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_card_rounded"
            android:stateListAnimator="@animator/card_press_anim"
            android:elevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/card_bluetooth_inspect"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/card_cellular_scan">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_circle_blue"
                    android:backgroundTint="#EFF6FF">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_lan"
                        app:tint="#2563EB"
                        android:layout_gravity="center" />
                </FrameLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="局域网扫描"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#0A1E36" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="内网与摄像头排查"
                    android:textSize="11sp"
                    android:textColor="#64748B"
                    android:layout_marginTop="3dp"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>
        </FrameLayout>

        <!-- Cellular Scan Card (Square) -->
        <FrameLayout
            android:id="@+id/card_cellular_scan"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintDimensionRatio="1:1"
            android:layout_marginTop="12dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="24dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_card_rounded"
            android:stateListAnimator="@animator/card_press_anim"
            android:elevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/card_bluetooth_inspect"
            app:layout_constraintStart_toEndOf="@id/card_lan_scan"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_circle_blue"
                    android:backgroundTint="#EFF6FF">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_cellular"
                        app:tint="#2563EB"
                        android:layout_gravity="center" />
                </FrameLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="基站扫描"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#0A1E36" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="伪基站与定位检测"
                    android:textSize="11sp"
                    android:textColor="#F59E0B"
                    android:layout_marginTop="3dp"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>
        </FrameLayout>
        <!-- Section Title: Security Monitor -->
        <LinearLayout
            android:id="@+id/section_monitor_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toBottomOf="@id/card_lan_scan"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="安全监测中心"
                android:textSize="15sp"
                android:fontFamily="sans-serif-black"
                android:textColor="#0A1E36" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_dashboard_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="实时防护中"
                android:textSize="11sp"
                android:textColor="#10B981"
                android:fontFamily="sans-serif-bold" />
        </LinearLayout>

        <!-- Dashboard Card -->
        <FrameLayout
            android:id="@+id/card_monitor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card_rounded"
            android:elevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/section_monitor_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- 3 stats columns -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:gravity="center_vertical">

                    <!-- Stat 1: Score -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_score_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="100"
                            android:textSize="22sp"
                            android:textColor="#10B981"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="安全指数"
                            android:textSize="10sp"
                            android:textColor="#64748B"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="24dp"
                        android:background="#E2E8F0" />

                    <!-- Stat 2: Whitelist -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_whitelist_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textColor="#0A1E36"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="可信设备"
                            android:textSize="10sp"
                            android:textColor="#64748B"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="24dp"
                        android:background="#E2E8F0" />

                    <!-- Stat 3: Scan records count -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_history_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textColor="#0A1E36"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="历史记录"
                            android:textSize="10sp"
                            android:textColor="#64748B"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F1F5F9"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp" />

                <!-- Details / Status sub-items -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Status Item 1: Bluetooth -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="2dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_bluetooth"
                            app:tint="#2563EB"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="蓝牙巡检状态"
                            android:textSize="12sp"
                            android:textColor="#1E293B"
                            android:fontFamily="sans-serif-medium" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tv_status_bluetooth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="运行正常"
                            android:textSize="11sp"
                            android:textColor="#10B981"
                            android:fontFamily="sans-serif-bold" />
                    </LinearLayout>

                    <!-- Status Item 2: WiFi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="2dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_wifi"
                            app:tint="#2563EB"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="WiFi安全盾"
                            android:textSize="12sp"
                            android:textColor="#1E293B"
                            android:fontFamily="sans-serif-medium" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tv_status_wifi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="运行正常"
                            android:textSize="11sp"
                            android:textColor="#10B981"
                            android:fontFamily="sans-serif-bold" />
                    </LinearLayout>

                    <!-- Status Item 3: Cellular -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="2dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_cellular"
                            app:tint="#2563EB"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="基站侦测"
                            android:textSize="12sp"
                            android:textColor="#1E293B"
                            android:fontFamily="sans-serif-medium" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tv_status_cellular"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="运行正常"
                            android:textSize="11sp"
                            android:textColor="#10B981"
                            android:fontFamily="sans-serif-bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
