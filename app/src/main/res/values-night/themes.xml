<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Signal_dectect" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_night</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary_night</item>
        
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        
        <!-- Background and surface colors -->
        <item name="android:windowBackground">@color/background_night</item>
        <item name="colorSurface">@color/surface_night</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/background_night</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Customize your theme here. -->
    </style>
</resources>